{
  "name": "saas",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && pnpm run type:check && pnpm run build:server && pnpm run build:client",
    "build:client": "NODE_ENV=production vite build && rm -rf dist/client && mkdir -p dist/client && mv src/dist/* dist/client/ && rm -rf src/dist",
    "build:server": "NODE_ENV=production tsdown -c scripts/tsdown.config.ts",
    "clean": "rm -rf dist",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:client": "NODE_ENV=development vite",
    "dev:server": "NODE_ENV=development tsx --env-file=.env --watch src/index.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "NODE_ENV=production node dist/index.mjs",
    "type:check": "tsc --noEmit",
    "type:check:staged": "node scripts/type-check-staged.js"
  },
  "author": "Dazum Dev <dazum.dev@gmail.com>",
  "dependencies": {
    "@fastify/caching": "^9.0.3",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/one-line-logger": "^2.1.0",
    "@fastify/static": "^9.1.3",
    "@redux-devtools/extension": "^4.0.0",
    "abstract-cache": "^1.0.1",
    "abstract-cache-redis": "^2.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.3.0",
    "react-router": "^7.16.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "reselect": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "rolldown": "^1.0.2",
    "sass": "^1.100.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.14",
    "vite-plugin-compression2": "^2.5.3",
    "wrangler": "4.98.0"
  }
}
